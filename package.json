{
  "name": "boop-watch",
  "private": true,
  "version": "2.60.0",
  "description": "Public, no-login viewing portal for a curated Jellyfin collection + library manager",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "build:all": "npm run build && npm run build:server",
