    "@xyflow/react": "^12.11.1",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "hls.js": "^1.6.16",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.511.0",
    "posthog-js": "^1.396.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "tailwind-merge": "^3.3.0"
